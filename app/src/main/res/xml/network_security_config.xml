<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext for user-configured router IPs.
         App-layer enforcement (RouterSecurityContext.httpRiskAccepted) gates
         all HTTP requests. See docs/SECURITY.md "HTTP Cleartext Policy". -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
