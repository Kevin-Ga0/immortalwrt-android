<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Release: allow cleartext for router IPs, app-layer enforcement active -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
